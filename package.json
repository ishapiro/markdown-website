{
  "name": "markdown-website",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt build && wrangler dev --config wrangler.toml --port 3001",
    "build": "nuxt build",
    "preview": "wrangler dev --config wrangler.toml --port 3001",
    "deploy": "nuxt build && wrangler deploy --config wrangler.toml",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node run-migrations.mjs",
    "db:migrate:remote": "node run-remote-migrations.mjs",
    "db:backup": "node backup-db.mjs",
    "db:restore": "node restore-db.mjs",
    "db:restore:list": "node restore-db.mjs --list",
    "push:cloudflare": "node push-to-cloudflare.mjs",
    "backup:cloudflare": "node backup-cloudflare.mjs",
    "backup:cloudflare:list": "node backup-cloudflare.mjs --list",
    "restore:cloudflare": "node restore-to-cloudflare.mjs",
    "restore:cloudflare:list": "node restore-to-cloudflare.mjs --list",
    "db:studio": "drizzle-kit studio",
    "db:studio:remote": "DRIZZLE_REMOTE_D1=1 drizzle-kit studio",
    "migrate": "node migrate.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "lucide-vue-next": "latest",
    "marked": "^12.0.0",
    "nuxt": "^3.13.0",
    "vue": "latest",
    "vue-router": "latest",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "latest",
    "@tailwindcss/typography": "latest",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.10",
    "globby": "^14.0.0",
    "typescript": "latest",
    "wrangler": "^4.79.0"
  }
}
